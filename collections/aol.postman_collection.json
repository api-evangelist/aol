              "body": "{\n  \"access_token\": \"string\",\n  \"token_type\": \"bearer\",\n  \"expires_in\": 3086,\n  \"refresh_token\": \"string\",\n  \"id_token\": \"string\",\n  \"xoauth_yahoo_guid\": \"string\"\n}",
