        {
          "id": "2cf08066-f31d-4b00-9c3d-2e5f020084f7",
          "name": "Token exchange and refresh",
          "request": {
            "name": "Token exchange and refresh",
            "description": {
              "content": "Exchanges an authorization code for access and refresh tokens, or\nexchanges a refresh token for a new access token. The `grant_type`\nparameter selects the behaviour. Client credentials may be passed\nin the body or in an `Authorization: Basic` header with\nbase64-encoded `client_id:client_secret`.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "oauth2",
                "get_token"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": []
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{basicAuthUsername}}"
                },
                {
                  "key": "password",
                  "value": "{{basicAuthPassword}}"
                }
              ]
            },
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "disabled": false,
                  "key": "client_id",
                  "value": "<string>",
                  "description": "(Required) Consumer Key"
                },
                {
                  "disabled": false,
                  "key": "client_secret",
                  "value": "<string>",
                  "description": "(Required) Consumer Secret"
                },
                {
                  "disabled": false,
                  "key": "redirect_uri",
                  "value": "<uri>",
                  "description": "(Required) Same redirect URI used in the authorization request"
                },
                {
                  "disabled": false,
                  "key": "grant_type",
                  "value": "<string>",
                  "description": "(Required) Selects code exchange or refresh-token exchange"
                },
                {
                  "disabled": false,
                  "key": "code",
                  "value": "<string>",
                  "description": "Authorization code returned from /oauth2/request_auth (required when grant_type=authorization_code)"
                },
                {
                  "disabled": false,
                  "key": "refresh_token",
                  "value": "<string>",
                  "description": "Previously issued refresh token (required when grant_type=refresh_token)"
                }
              ]
            }
          },
          "response": [
            {
              "id": "fde261ca-730f-4d48-b1a6-aaad2ccb8bc4",
