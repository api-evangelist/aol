    {
      "id": "a444a1e6-454a-41e3-84a9-0f4f0e4878b6",
      "name": "OAuth2",
      "description": {
        "content": "OAuth 2.0 Authorization Code grant endpoints",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "13ec33d9-be33-49b4-81ce-8c8f4caae42a",
          "name": "Authorization request",
          "request": {
            "name": "Authorization request",
            "description": {
              "content": "Redirects the user to Yahoo's authorization page where the user\nauthenticates and grants the requesting application access. On\nsuccess Yahoo redirects back to `redirect_uri` with a `code`\nquery parameter that can be exchanged at the token endpoint.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "oauth2",
                "request_auth"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "client_id",
                  "value": "<string>",
                  "description": "(Required) Consumer Key issued when registering an app at developer.yahoo.com"
                },
                {
                  "disabled": false,
                  "key": "redirect_uri",
                  "value": "<uri>",
                  "description": "(Required) URI Yahoo will redirect to after the user authorizes the app"
                },
                {
                  "disabled": false,
                  "key": "response_type",
                  "value": "<string>",
                  "description": "(Required) Must be `code` for the Authorization Code grant"
                },
                {
                  "disabled": false,
                  "key": "scope",
                  "value": "<string>",
                  "description": "Space-separated OpenID Connect scopes (for example `openid profile email`)"
                },
                {
                  "disabled": false,
                  "key": "state",
                  "value": "<string>",
                  "description": "Opaque value returned unchanged on the redirect; use to prevent CSRF"
                },
                {
                  "disabled": false,
                  "key": "language",
                  "value": "en-us",
                  "description": "Language identifier for the Yahoo authorization UI"
                }
              ],
              "variable": []
            },
            "method": "GET",
            "auth": null
          },
          "response": [
            {
              "id": "4eefee63-097e-4d9e-a134-a4c8a1d58636",
              "name": "Redirect to the configured `redirect_uri` with `code` and `state` query parameters on success, or with `error` on failure.",
              "originalRequest": {
                "url": {
                  "path": [
                    "oauth2",
                    "request_auth"
                  ],
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "query": [
                    {
                      "key": "client_id",
                      "value": "<string>"
                    },
                    {
                      "key": "redirect_uri",
                      "value": "<uri>"
                    },
                    {
                      "key": "response_type",
                      "value": "<string>"
                    },
                    {
                      "key": "scope",
                      "value": "<string>"
                    },
                    {
                      "key": "state",
                      "value": "<string>"
                    },
                    {
                      "key": "language",
                      "value": "en-us"
                    }
                  ],
                  "variable": []
                },
                "method": "GET",
                "body": {}
              },
              "status": "Found",
              "code": 302,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "text/plain"
                }
              ],
